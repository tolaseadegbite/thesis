<section id="outline_section">
  <h2>Outline</h2>

  <% if thesis.draft? %>
    <p>Generating outline... <span class="spinner"></span></p>
    <%= tag.progress class: "progress", role: "progressbar" %>

  <% elsif thesis.outline_submitted? %>
    <%= render "theses/outline_editor", thesis: thesis %>

  <% elsif thesis.outline.present? && thesis.outline["chapters"] %>
    <ul>
      <% thesis.outline["chapters"].each do |ch| %>
        <li>
          <strong><%= ch["title"] %></strong>
          <% if ch["subsections"]&.any? %>
            <ul style="margin-bottom: 0.5rem; font-size: 0.9rem; color: #4b5563;">
              <% ch["subsections"].each do |sub| %>
                <li class="mis-5"><%= sub %></li>
              <% end %>
            </ul>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p><em>Outline not yet generated.</em></p>
  <% end %>
</section>