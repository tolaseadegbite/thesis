<div id="actions_section" class="actions">
  <%# 1. Start Drafting button %>
  <% if thesis.research_done? && thesis.fact_review_completed? %>
    <%= button_to "Start Drafting", start_drafting_thesis_path(thesis), method: :post, class: "btn" %>
  <% end %>

  <%# 2. Start Verification Form (shows when all chapters are draft_complete) %>
  <% if (thesis.drafting? || thesis.verification?) && thesis.chapters.all?(&:draft_complete?) && thesis.chapters.any? { |ch| !ch.verified? } %>
    <%= form_with url: start_verification_thesis_path(thesis), method: :post, class: "verification-form" do |f| %>
      <div class="depth-selector" style="margin-bottom: 1rem;">
        <strong>Verification Depth:</strong>
        <label style="margin-left: 10px;"><input type="radio" name="depth" value="strict"> Strict</label>
        <label style="margin-left: 10px;"><input type="radio" name="depth" value="moderate" checked> Moderate</label>
        <label style="margin-left: 10px;"><input type="radio" name="depth" value="light"> Light</label>
      </div>
      <%= f.submit "Start Verification", class: "btn" %>
    <% end %>
  <% end %>

  <%# 3. Download button %>
  <% if thesis.complete? %>
    <% if thesis.pdf_none? %>
      <%= button_to "Assemble Final PDF", generate_pdf_thesis_path(thesis), method: :post, class: "btn" %>
    
    <% elsif thesis.pdf_generating? %>
      <button class="btn" disabled style="opacity: 0.7; cursor: wait;">
        <span class="spinner" style="width: 12px; height: 12px; border-width: 2px; margin-right: 8px;"></span>
        Assembling Chapters...
      </button>

    <% elsif thesis.pdf_ready? %>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <p style="color: #059669; font-weight: bold; margin: 0;">✨ Thesis Ready for Download</p>
        <%= link_to "Download PDF Now", download_pdf_thesis_path(thesis), class: "btn", data: { turbo: false } %>
        <%= button_to "Re-generate PDF", generate_pdf_thesis_path(thesis), method: :post, style: "background: none; border: none; color: #6b7280; text-decoration: underline; cursor: pointer; font-size: 0.8rem;" %>
      </div>
    <% end %>
  <% end %>
</div>