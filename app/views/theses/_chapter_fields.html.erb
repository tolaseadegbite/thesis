<%# If f is not passed (e.g. from the add_chapter stream), we create a standalone builder %>
<% 
  unless local_assigns[:f]
    child_index = Time.now.to_i
    f = ActionView::Helpers::FormBuilder.new("thesis[chapters_attributes][#{child_index}]", chapter, self, {})
  end
%>

<fieldset class="chapter-field" style="border: 1px solid #ddd; padding: 1rem; margin-bottom: 1rem; border-radius: 8px;">
  <%# 1. ID is required for existing records to be updated instead of created new %>
  <%= f.hidden_field :id if chapter.persisted? %>

  <div style="display: grid; grid-template-columns: 1fr 100px auto; gap: 1rem; align-items: end;">
    <div>
      <%= f.label :title, "Chapter Title" %>
      <%= f.text_field :title, class: "input", placeholder: "e.g., Introduction" %>
    </div>

    <div>
      <%= f.label :order %>
      <%= f.number_field :order, class: "input" %>
    </div>

    <div>
      <% if chapter.persisted? %>
        <%# 2. _destroy must be at the same level as title and order %>
        <%= f.hidden_field :_destroy, value: 0, class: "destroy-flag" %>
        <button type="button" class="btn btn-danger" 
                onclick="this.previousElementSibling.value = '1'; this.closest('fieldset').style.display = 'none'">
          Remove
        </button>
      <% else %>
        <button type="button" class="btn btn-danger" onclick="this.closest('fieldset').remove()">
          Cancel
        </button>
      <% end %>
    </div>
  </div>
</fieldset>