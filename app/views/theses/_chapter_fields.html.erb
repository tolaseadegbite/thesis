<%# Robust builder for both page load and Turbo Stream appends %>
<% 
  unless local_assigns[:f]
    # This specifically fixes the "Unpermitted parameters" bug by nesting under thesis[chapters_attributes]
    f = ActionView::Helpers::FormBuilder.new("thesis[chapters_attributes][#{child_index}]", chapter, self, {})
  end
%>

<fieldset class="chapter-field" data-budget-target="chapter" style="border: 1px solid #ddd; padding: 1rem; margin-bottom: 1rem; border-radius: 8px; background: #fff;">
  <%= f.hidden_field :id if chapter.persisted? %>

  <div style="display: flex; gap: 1rem; align-items: flex-start;">
    
    <div class="drag-handle" style="margin-top: 2.1rem; cursor: grab; font-size: 1.5rem; color: #9ca3af;" title="Drag to reorder">
      ☰
    </div>

    <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 10px;">
      <div>
        <%= f.label :title, "Chapter Title" %>
        <%= f.text_field :title, placeholder: "e.g., Introduction", 
            class: "input #{'is-invalid' if f.object.errors[:title].any?}" %>
        <% if f.object.errors[:title].any? %>
          <div style="color: #dc2626; font-size: 0.85rem; margin-top: 4px;">Chapter title cannot be blank</div>
        <% end %>
      </div>
      
      <div>
        <%= f.label :subsections_string, "Subsections (comma separated)" %>
        <%= f.text_area :subsections_string, class: "input", rows: 2, placeholder: "Background, Methodology..." %>
      </div>
    </div>

    <%# Hidden so drag-and-drop handles the value, but Rails still receives the data %>
    <%= f.hidden_field :order, class: "order-input" %>

    <div style="margin-top: 1.5rem;">
      <% if chapter.persisted? %>
        <%= f.hidden_field :_destroy, value: 0, class: "destroy-flag" %>
        <button type="button" class="btn btn-danger" 
                onclick="
                  this.previousElementSibling.value = '1'; 
                  this.closest('fieldset').style.display = 'none'; 
                  document.querySelector('#chapters-fields').dispatchEvent(new CustomEvent('sortable-update'));
                ">
          Remove
        </button>
      <% else %>
        <button type="button" class="btn btn-danger" 
                onclick="
                  this.closest('fieldset').remove(); 
                  document.querySelector('#chapters-fields').dispatchEvent(new CustomEvent('sortable-update'));
                ">
          Cancel
        </button>
      <% end %>
    </div>
  </div>
</fieldset>