<h2>Edit Outline & Budget</h2>

<%# 1. Attach the budget controller and pass the ruby constants as data values %>
<%= form_with model: thesis, url: approve_outline_thesis_path(thesis), method: :post, 
    data: { 
      controller: "budget", 
      budget_paper_cost_value: Thesis::COST_PER_PAPER,
      budget_chapter_cost_value: Thesis::COST_PER_CHAPTER,
      action: "sortable-update->budget#calculate" 
    } do |f| %>
  
  <%# 2. The Dynamic Budget Panel %>
  <div class="budget-panel">
    <strong>Scope & Budget Estimate:</strong><br>
    Deep Researcher should fetch up to 
    <%= f.number_field :target_paper_count, 
          class: "input", 
          style: "width: 80px; display: inline-block; margin: 0 5px;", 
          min: 1, max: 100, 
          data: { budget_target: "paperCount", action: "input->budget#calculate" } %> 
    papers.<br>
    <span style="display: inline-block; margin-top: 8px;">
      Estimated compute cost for Research + Drafting: <strong>$<span data-budget-target="costDisplay"><%= format('%.2f', thesis.calculate_cost_estimate) %></span></strong>
    </span>
  </div>

  <div id="chapters-fields" data-controller="form-sortable" data-action="sortable-update->form-sortable#updateOrder">
    <%= f.fields_for :chapters do |chapter_form| %>
      <%= render "theses/chapter_fields", f: chapter_form, chapter: chapter_form.object %>
    <% end %>
  </div>

  <div class="outline-actions" style="margin-top: 1.5rem; display: flex; gap: 1rem;">
    <%= link_to "Add Chapter", add_chapter_thesis_path(thesis), 
                data: { turbo_method: :post }, class: "btn btn-secondary" %>
    <%= f.submit "Save Changes & Start Research", class: "btn btn-primary" %>
  </div>
<% end %>